rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isProfessor() {
      return isSignedIn() && exists(/databases/$(database)/documents/professors/$(request.auth.uid));
    }

    // Professors Collection
    match /professors/{uid} {
      allow read, write: if isOwner(uid);
      allow list: if isProfessor();
    }

    // Students Collection
    match /students/{uid} {
      allow read, write: if isOwner(uid);
      allow list: if isProfessor();
    }

    // Assignments Collection
    match /assignments/{assignmentId} {
      allow read, list: if isSignedIn();
      allow create: if isProfessor() && request.resource.data.professorId == request.auth.uid;
      allow update, delete: if isOwner(resource.data.professorId) || isProfessor();
    }

    // Submissions Collection
    match /submissions/{submissionId} {
      allow read, list: if isSignedIn() && (isOwner(resource.data.studentUid) || isProfessor());
      allow create: if isSignedIn() && request.resource.data.studentUid == request.auth.uid;
      allow update, delete: if isSignedIn() && (isOwner(resource.data.studentUid) || isProfessor());
    }

    // Drafts Collection
    match /drafts/{draftId} {
      allow read, write: if isSignedIn() && (isOwner(resource.data.uid) || isOwner(request.resource.data.uid));
    }

    // Audit Usage Collection
    match /audit_usage/{usageId} {
      allow read, write: if isSignedIn() && (isOwner(resource.data.studentUid) || isOwner(request.resource.data.studentUid));
    }
  }
}
